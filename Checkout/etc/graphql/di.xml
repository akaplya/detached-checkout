<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <!-- Map the ITEM_EXPIRED cart item error onto the CartItemErrorType enum -->
    <type name="Magento\Framework\GraphQl\Schema\Type\Enum\DefaultDataMapper">
        <arguments>
            <argument name="map" xsi:type="array">
                <item name="CartItemErrorType" xsi:type="array">
                    <item name="item_expired" xsi:type="string">100</item>
                </item>
            </argument>
        </arguments>
    </type>
</config>
